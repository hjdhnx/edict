# ── Edict 三省六部 事件驱动架构 ──
# 复制为 .env 并根据环境修改

# ── Postgres ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=edict
POSTGRES_USER=edict
POSTGRES_PASSWORD=change-me

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Backend ──
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=change-me-in-production
DEBUG=false
CORS_ORIGINS=http://localhost:7899

# ── OpenClaw Gateway ──
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_BIN=openclaw

# ── Agent Runtime ──
DISPATCH_BACKEND=openclaw  # openclaw | astrbot

# ── AstrBot ──
ASTRBOT_API_URL=http://localhost:6185
# Set this in your local .env; do not commit real AstrBot API keys.
ASTRBOT_API_KEY=
ASTRBOT_TIMEOUT_SEC=300
# 可选：指定 AstrBot WebChat 配置，让 HTTPAPI 会话走与 WebUI/QQ 相同的配置路由
# 二选一即可；优先使用 ASTRBOT_CONFIG_ID
ASTRBOT_CONFIG_ID=
ASTRBOT_CONFIG_NAME=

# ── 文件路径（兼容旧系统过渡期） ──
LEGACY_DATA_DIR=../data
LEGACY_TASKS_FILE=../data/tasks_source.json

# ── 调度参数 ──
STALL_THRESHOLD_SEC=180
MAX_DISPATCH_RETRY=3
DISPATCH_TIMEOUT_SEC=300
HEARTBEAT_INTERVAL_SEC=30

# ── 消息通知 ──
NOTIFICATION_ENABLED=true
DEFAULT_DISPATCH_CHANNEL=wecom
